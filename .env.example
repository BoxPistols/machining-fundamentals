# =============================================================================
# .env.example  —  ローカル開発用テンプレート
# このファイルを .env にコピーして値を埋める: cp .env.example .env
# .env は .gitignore 済 (コミットしない)
# =============================================================================

# -----------------------------------------------------------------------------
# [LOCAL] scripts/chat-conn-test.sh 用
#   ローカルで Worker を介さず直接プロバイダ API を叩くキーの妥当性検証に使う。
# -----------------------------------------------------------------------------

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# [REMOTE リファレンス] Cloudflare Workers 側で設定する値
#   これらは .env ではなく Worker Settings > Variables and Secrets に設定する。
#   ここには必要な変数名と目安値だけ記録 (実キーは書かない)。
#   設定手順: docs/phase-0/runbook.md 参照
# -----------------------------------------------------------------------------

# --- Chat 用 Worker (machining-chat) ---
#   OPENAI_API_KEY       (Secret, 必須)  Anonymous / Invited tier で使用
#   GEMINI_API_KEY       (Secret, 任意)  Gemini モデル提供する場合
#   ALLOWED_ORIGIN       (Text, 推奨)   https://machining-fundamentals.vercel.app
#   PROXY_SHARED_SECRET  (Secret, 任意)  BYOK 利用時の追加認証
#   RATE_LIMIT_KV        (KV Binding, 必須)  日次カウンタの永続化
#   INVITE_KV            (KV Binding, 任意)  招待コード機能を使う場合

# 制限調整 (いずれも Text、省略時の既定値は worker-proxy.js の CHAT_DEFAULTS 参照):
#   CHAT_LIMIT_ANON_REQ=50
#   CHAT_LIMIT_INVITED_REQ=100
#   CHAT_LIMIT_TOKENS_ANON=150000
#   CHAT_LIMIT_TOKENS_INVITED=300000
#   CHAT_MAX_INPUT_TOKENS=4000
#   CHAT_MAX_OUTPUT_TOKENS=800

# --- TTS 用 Worker (現在 grok-tts-proxy、将来 machining-tts へ移行想定) ---
#   XAI_API_KEY          (Secret, TTS Shared モードで必須)
#   ALLOWED_ORIGIN       (Text, 推奨)
#   RATE_LIMIT_PER_DAY   (Text, 任意)  省略時 30

# -----------------------------------------------------------------------------
# 備考
# -----------------------------------------------------------------------------
# - OpenAI / Gemini キー発行は docs/phase-0/runbook.md の Step 1 参照
# - OpenAI 側の Monthly budget limit は必ず設定する (Cloudflare 側の rate limit
#   を突破された最悪ケースでもコスト暴発を止めるため)
# - .env は絶対にコミットしない (.gitignore で保護済)
